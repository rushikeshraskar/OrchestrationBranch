pipeline {
  agent any

  parameters {
    string(name: 'BASE_BRANCH', defaultValue: 'release-8.5.x', description: 'Base branch')
    string(name: 'NEW_BRANCH',  description: 'New branch to create (e.g. release-8.5.1)')
  }

  stages {
    stage('Checkout Product Repository') {
      steps {
        checkout(
          [
            $class: 'GitSCM',
            branches: [[name: "*/${params.BASE_BRANCH}"]],
            userRemoteConfigs: [[
              url: 'https://github.com/rushikeshraskar/DemoRepoForProduct1.git',
              credentialsId: 'f97287c6-60a4-439b-ad3e-d8afbec1ffd7'
            ]]
          ]
        )
        echo "✅ Product repository checked out successfully"
      }
    }

    stage('Call Branch Cut Jenkins File') {
      steps {
        script {
          echo "📋 Calling branchCutJenkins from product repository..."
          echo "   Base Branch: ${params.BASE_BRANCH}"
          echo "   New Branch: ${params.NEW_BRANCH}"
          
          // Load and execute the Jenkins file from the product repo
          def branchCutJob = load "jenkins/branchCutJenkins"
          
          // Call the pipeline with parameters
          branchCutJob.call([
            BASE_BRANCH: params.BASE_BRANCH,
            NEW_BRANCH: params.NEW_BRANCH
          ])
        }
      }
    }
  }

  post {
    success {
      echo "🎉 Branch cut operation completed successfully!"
      echo "   Branch: ${params.NEW_BRANCH}"
      echo "   Created from: ${params.BASE_BRANCH}"
    }
    failure {
      echo "❌ Branch cut operation failed"
      echo "   Check the product repository Jenkins file for details"
    }
    unstable {
      echo "⚠️ Operation unstable - check logs above"
    }
  }
}
