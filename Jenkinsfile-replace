pipeline {
  agent any

  parameters {
    string(
      name: 'SEARCH_TEXT',
      description: 'Text to search for in .env file (e.g., VERSION=1.0.0)',
      defaultValue: ''
    )
    string(
      name: 'REPLACE_TEXT',
      description: 'Text to replace with (e.g., VERSION=2.0.0)',
      defaultValue: ''
    )
    string(
      name: 'SOURCE_BRANCH',
      description: 'Source branch to checkout from',
      defaultValue: 'main'
    )
    string(
      name: 'TARGET_BRANCH',
      description: 'Target branch to create and push to',
      defaultValue: ''
    )
  }

  stages {
    stage('Validate Parameters') {
      steps {
        script {
          if (!params.SEARCH_TEXT?.trim()) {
            error "❌ Error: SEARCH_TEXT parameter is required"
          }
          if (!params.REPLACE_TEXT?.trim()) {
            error "❌ Error: REPLACE_TEXT parameter is required"
          }
          if (!params.TARGET_BRANCH?.trim()) {
            error "❌ Error: TARGET_BRANCH parameter is required"
          }
          echo "✅ All parameters validated"
          echo "   Search Text: ${params.SEARCH_TEXT}"
          echo "   Replace Text: ${params.REPLACE_TEXT}"
          echo "   Source Branch: ${params.SOURCE_BRANCH}"
          echo "   Target Branch: ${params.TARGET_BRANCH}"
        }
      }
    }

    stage('Checkout spring-auth-app') {
      steps {
        checkout(
          [
            $class: 'GitSCM',
            branches: [[name: '*/main']],
            userRemoteConfigs: [[url: 'https://github.com/rushikeshraskar/spring-auth-app.git']]
          ]
        )
        echo "✅ spring-auth-app checked out successfully"
      }
    }

    stage('Execute Replace and Push') {
      steps {
        withCredentials([usernamePassword(
          credentialsId: 'f97287c6-60a4-439b-ad3e-d8afbec1ffd7',
          usernameVariable: 'GIT_USER',
          passwordVariable: 'GIT_TOKEN'
        )]) {
          script {
            // On Windows agents, run the batch file directly
            if (isUnix()) {
              error "❌ This job requires a Windows agent to run the .bat script"
            } else {
              bat '''
                echo ========================================
                echo Git Replacement Script Execution
                echo ========================================
                
                REM Configure git credentials
                git config --global user.name "jenkins-bot"
                git config --global user.email "jenkins@ci.local"
                
                REM Call the replace.bat script with parameters
                call scripts\\replace.bat "%SEARCH_TEXT%" "%REPLACE_TEXT%" "%SOURCE_BRANCH%" "%TARGET_BRANCH%"
                
                if errorlevel 1 (
                  echo ❌ Script execution failed
                  exit /b 1
                )
                
                echo ✅ Script execution completed successfully
              '''
            }
          }
        }
      }
    }
  }

  post {
    success {
      echo "✅ Pipeline completed successfully!"
      echo "📋 Summary:"
      echo "   - Cloned: https://github.com/rushikeshraskar/TestCPRepo1"
      echo "   - Source Branch: ${params.SOURCE_BRANCH}"
      echo "   - Target Branch: ${params.TARGET_BRANCH}"
      echo "   - Replacement: ${params.SEARCH_TEXT} → ${params.REPLACE_TEXT}"
      echo "   - Changes pushed to target branch"
    }
    failure {
      echo "❌ Pipeline failed"
      echo "   Check the logs above for details"
    }
    unstable {
      echo "⚠️ Pipeline unstable"
    }
  }
}
